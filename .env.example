# Server
PORT=3010
API_KEY=

# Workspace root for agent tools (write_file, read_file, workspace, …)
# Default: <ManusProxy>/workspace
MANUS_WORKSPACE=

# Browser: chromium | chrome | edge | firefox
BROWSER=chrome

# Account id for multi-profile (default)
MANUS_ACCOUNT=default

# Headless chrome by default (true). Use --headed or MANUS_HEADLESS=false for UI.
MANUS_HEADLESS=true

# AES vault secret for account metadata + response store.
# If unset, auto-generates manus_profiles/.store_key (keep this file private).
MANUS_STORE_SECRET=

# Debug Socket.IO frames
MANUS_WS_DEBUG=false

# How to expose Manus thinking on SSE (for OpenCode / agents):
#   reasoning_content = delta.reasoning_content only (default — clean for agents)
#   both              = reasoning_content + <think> tags (only before answer)
#   content_tags      = only <think> in content
#   off               = disable
MANUS_THINK_MODE=reasoning_content
